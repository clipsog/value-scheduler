# --- Local API (Express, port 8788) ---
# Default matches Docker Postgres from `npm run db:up`
DATABASE_URL=postgresql://assets:assets_dev@127.0.0.1:54331/value_scheduler

# Render: Supabase direct db.*:5432 is often IPv6-only. Set pooler segment from Dashboard → Connect:
# SUPABASE_POOLER_REGION=aws-1-us-west-2
# Or: SUPABASE_POOLER_HOST=aws-1-us-west-2.pooler.supabase.com
# (Keeps DATABASE_URL as the direct URI; the API rewrites to postgres.<ref>@pooler:6543.)

# Optional row id (default asset-scheduler-main)
# ASSET_SCHEDULER_ROW_ID=asset-scheduler-main

# --- Vite client (Supabase browser sync) ---
# New project: Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Optional: skip cloud sync while developing
# VITE_DISABLE_CLOUD_SYNC=true

# --- Lucid (Goalachiever) — https://github.com/clipsog/Goalachiever ---
# HTTPS URL + anon key (not the Postgres pooler). If omitted, the app uses VITE_SUPABASE_* above
# when Lucid lives in the same Supabase project (typical).
# VITE_LUCID_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# VITE_LUCID_SUPABASE_ANON_KEY=eyJ...

# --- One-off DB migration (`npm run db:migrate-to-pg`) ---
# Pooler URI from Supabase → Connect → Transaction pooler. Encode each $ in the password as %24.
# TARGET_DATABASE_URL=postgresql://postgres.YOUR_REF:ENCODED_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# Source (pick one):
# SOURCE_DATABASE_URL=postgresql://assets:assets_dev@127.0.0.1:54331/value_scheduler
# SOURCE_STATE_BASE_URL=http://127.0.0.1:5190
